# ── LLM Provider ──────────────────────────────────────────────────────────────
# "vllm"      = local AMD MI300X server (default, recommended for hackathon)
# "anthropic" = Anthropic cloud
# "auto"      = vLLM if VLLM_BASE_URL is reachable, else Anthropic
LLM_PROVIDER=vllm

# ── vLLM — AMD MI300X local inference ─────────────────────────────────────────
# Port 8001 keeps vLLM separate from FastAPI (port 8000).
#
# Launch command (in a separate terminal):
#
#   VLLM_USE_TRITON_FLASH_ATTN=0 \
#   vllm serve Qwen/Qwen3-14B \
#       --served-model-name Qwen3-14B \
#       --api-key abc-123 \
#       --port 8001 \
#       --enable-auto-tool-choice \
#       --tool-call-parser hermes \
#       --trust-remote-code \
#       --dtype bfloat16
#
# Recommended models (all <60B, ROCm-compatible):
#   Qwen/Qwen3-14B              (14B dense  — fast + excellent tool calling)
#   Qwen/Qwen2.5-32B-Instruct   (32B dense  — best quality under 60B)
#   Qwen/Qwen3-30B-A3B          (30B MoE    — 3B active params, near-32B quality)
#   deepseek-ai/DeepSeek-R1-Distill-Qwen-32B  (32B — best reasoning/judge)
#   meta-llama/Llama-3.1-8B-Instruct          (8B  — fastest, good for alerts)

VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=abc-123
VLLM_MODEL=Qwen3-14B
# Set to true for Qwen3 models (strips <think> blocks from outputs)
VLLM_MODEL_HAS_THINKING=true

# ── Anthropic cloud fallback (optional) ───────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── LangSmith tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=idtcc-production

# ── App settings ──────────────────────────────────────────────────────────────
DEFAULT_LOCATION=CHN
DEFAULT_TWIN_COUNT=50000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
