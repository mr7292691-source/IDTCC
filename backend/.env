# LLM Provider: "vllm" = local AMD GPU | "anthropic" = cloud | "auto" = try vllm first
# Set to "anthropic" and add ANTHROPIC_API_KEY if you don't have vLLM running locally
LLM_PROVIDER=vllm

# vLLM local server (AMD MI300X, port 8001)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=abc-123
VLLM_MODEL=Qwen3-14B
VLLM_MODEL_HAS_THINKING=true

# Anthropic cloud fallback (fill in your key to use instead of vLLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# LangSmith tracing (optional — fill in key to enable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=idtcc-production

# App
DEFAULT_LOCATION=CHN
DEFAULT_TWIN_COUNT=50000
LOG_LEVEL=INFO
