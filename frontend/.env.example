# Backend API base URL.
#
# Leave EMPTY (recommended) to use same-origin requests, which the Vite dev
# server proxies to the backend (see vite.config.js) and which work in
# production when the API is served from the same origin. The backend does NOT
# enable CORS, so only set an absolute cross-origin URL if you have a proxy.
VITE_API_URL=

# Where the Vite dev proxy forwards /api, /health, /metrics (dev only).
VITE_PROXY_TARGET=http://localhost:8000
